{% doc %}
  @prompt
    craft nme a custom slider named tss slider for all 
    all slidesho feature will available but 
    the banner/image which will be desktop version also be on the same at the mobile but zoomed out and it will not cut 
    on any direction
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.tss-slider-{{ ai_gen_id }} {
  position: relative;
  width: {{ block.settings.desktop_width_percent }}%;
  max-width: 100%;
  overflow: hidden;
  display: block;
  padding-top: {{ block.settings.padding_top }}px;
  padding-bottom: {{ block.settings.padding_bottom }}px;
}

  .tss-slider__viewport-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .tss-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .tss-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tss-slider__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .tss-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .tss-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 400px;
  }

  .tss-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .tss-slider__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .tss-slider__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 600px;
    z-index: 2;
  }

  .tss-slider__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  .tss-slider__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  .tss-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .tss-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .tss-slider__controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 3;
    pointer-events: none;
  }

  .tss-slider__arrow-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
    pointer-events: auto;
  }

  .tss-slider__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
  }

  .tss-slider__arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .tss-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .tss-slider__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .tss-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .tss-slider-{{ ai_gen_id }} {
  padding-top: {{ block.settings.padding_top_mobile }}px;
  padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
}
    .tss-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .tss-slider__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .tss-slider__arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .tss-slider__arrow-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }
{% endstyle %}

<tss-slider-{{ ai_gen_id }} class="tss-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="tss-slider__viewport-{{ ai_gen_id }}">
    <div class="tss-slider__track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign subheading_key = 'slide_' | append: i | append: '_subheading'
          assign button_text_key = 'slide_' | append: i | append: '_button_text'
          assign button_link_key = 'slide_' | append: i | append: '_button_link'

          assign slide_image = block.settings[image_key]
          assign slide_heading = block.settings[heading_key]
          assign slide_subheading = block.settings[subheading_key]
          assign slide_button_text = block.settings[button_text_key]
          assign slide_button_link = block.settings[button_link_key]
        %}

        <div class="tss-slider__slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
          <div class="tss-slider__image-wrapper-{{ ai_gen_id }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="tss-slider__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="tss-slider__placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                {% if forloop.first %}
                  <div class="tss-slider__empty-state-{{ ai_gen_id }}">
                    Add images to your slides
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>

          {% if slide_heading != blank or slide_subheading != blank or slide_button_text != blank %}
            <div class="tss-slider__content-{{ ai_gen_id }}">
              {% if slide_heading != blank %}
                <h2 class="tss-slider__heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
              {% endif %}

              {% if slide_subheading != blank %}
                <p class="tss-slider__subheading-{{ ai_gen_id }}">{{ slide_subheading }}</p>
              {% endif %}

              {% if slide_button_text != blank %}
                <a
                  href="{{ slide_button_link | default: '#' }}"
                  class="tss-slider__button-{{ ai_gen_id }}"
                >
                  {{ slide_button_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if block.settings.show_arrows %}
    <div class="tss-slider__controls-{{ ai_gen_id }}">
      <button
        class="tss-slider__arrow-{{ ai_gen_id }} tss-slider__arrow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="tss-slider__arrow-{{ ai_gen_id }} tss-slider__arrow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}

  {% if block.settings.show_dots %}
    <div class="tss-slider__dots-{{ ai_gen_id }}"></div>
  {% endif %}
</tss-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TssSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 5;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.tss-slider__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.tss-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.tss-slider__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.tss-slider__arrow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.tss-slider__dots-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.createDots();
        this.updateSlider();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        {% if block.settings.swipe_enabled %}
          let startX = 0;
          let currentX = 0;
          let isDragging = false;

          this.track.addEventListener('touchstart', (e) => {
            startX = e.touches[0].clientX;
            isDragging = true;
          });

          this.track.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            currentX = e.touches[0].clientX;
          });

          this.track.addEventListener('touchend', () => {
            if (!isDragging) return;
            const diff = startX - currentX;
            if (Math.abs(diff) > 50) {
              if (diff > 0) {
                this.nextSlide();
              } else {
                this.prevSlide();
              }
            }
            isDragging = false;
          });
        {% endif %}
      }

      createDots() {
        if (!this.dotsContainer) return;

        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.classList.add('tss-slider__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateSlider() {
        this.track.style.transform = `translateX(-${this.currentSlide * 100}%)`;

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.tss-slider__dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            if (index === this.currentSlide) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        this.updateSlider();
        this.resetAutoplay();
      }

      prevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlider();
        this.resetAutoplay();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
        this.resetAutoplay();
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.startAutoplay();
          }
        {% endif %}
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('tss-slider-{{ ai_gen_id }}', TssSlider{{ ai_gen_id }});
  })();
</script>

